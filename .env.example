PORT=8080
GRPC_PORT=9090

DATABASE_URL=postgres://xoxa:xoxa@localhost:5432/xoxa?sslmode=disable
NATS_URL=nats://localhost:4222

JWT_ISSUER=xoxa-gateway
JWT_AUDIENCE=internal
JWT_SECRET=supersecret
# Alternative to JWT_SECRET: verify RS256 tokens with an RSA public key instead.
# JWT_PUBLIC_KEY_PATH=./keys/jwt.pub

OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=xoxa-message-gateway

# Twilio (channel: "sms")
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# WhatsApp Cloud API (channel: "whatsapp")
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_BASE=https://graph.facebook.com/v19.0

MAX_SEND_ATTEMPTS=5
BASE_RETRY_DELAY=1s
